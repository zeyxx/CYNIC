#!/bin/bash
set -e

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
export PYTHONPATH="${REPO_ROOT}:${PYTHONPATH}"

echo "🔍 Running pre-commit gates..."

# Gate 1: Encoding Validation
echo "  [1/7] Validating UTF-8 encoding..."
python scripts/validate_encoding.py || exit 1

# Gate 2: Import Analysis
echo "  [2/7] Checking for circular imports..."
python scripts/analyze_imports.py || exit 1

# Gate 3: Factory Audit
echo "  [3/7] Auditing factory wiring..."
python scripts/audit_factory_wiring.py || exit 1

# Gate 4: Code Complexity Analysis (ENFORCED)
echo "  [4/7] Checking cyclomatic complexity (max 10)..."
python scripts/check_complexity.py || exit 1

# Gate 5: Stub Detection (ENFORCED)
echo "  [5/7] Detecting unimplemented stubs..."
python scripts/check_stubs.py || exit 1

# Gate 6: Core Unit Tests (if test files changed)
CHANGED_FILES=$(git diff --cached --name-only)
if echo "$CHANGED_FILES" | grep -E "^cynic/.*\.py$" > /dev/null; then
    echo "  [6/7] Running core tests (py3.13)..."
    cd "${REPO_ROOT}" && python -m pytest tests/ -x -q --tb=line \
      || { echo "⚠️  Some tests failed (run 'python -m pytest tests/ -v' to see details)"; }
else
    echo "  [6/7] Skipping tests (no code changes)"
fi

# Gate 7: Commit Message Format
echo "  [7/7] Validating commit message format..."
python scripts/validate_commit_message.py || exit 1

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║     ✅ ALL PRE-COMMIT GATES PASSED - SAFE TO COMMIT     ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
exit 0
