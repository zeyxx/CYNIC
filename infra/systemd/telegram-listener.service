[Unit]
Description=CYNIC Telegram Listener
After=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=%h/cynic/cynic-python
ExecStart=%h/.cynic/organs/telegram/.venv/bin/python -m organs.telegram.listener
Restart=on-failure
RestartSec=30
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/.config/cynic/env
EnvironmentFile=-%h/.cynic/organs/telegram/env
# Cgroup limits — observed: 268MB.
MemoryMax=512M

[Install]
WantedBy=default.target
