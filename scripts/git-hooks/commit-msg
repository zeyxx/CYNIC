#!/bin/sh
# CYNIC — Conventional commits enforcement (Layer 2, agnostic)
# Types: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release
MSG=$(head -1 "$1")

# Skip auto-generated messages (fixup, squash, merge, amend)
case "$MSG" in
    fixup!*|squash!*|amend!*) exit 0 ;;
    Merge\ *) exit 0 ;;
    Revert\ \"*) exit 0 ;;
esac

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release|harden|burn|rules)(\([a-z0-9._-]+\))?(!)?: .{1,100}'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
    echo "ERROR: Commit message does not follow Conventional Commits."
    echo "Expected: type(scope): description"
    echo "Types: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release|harden|burn|rules"
    echo ""
    echo "Got: $MSG"
    exit 1
fi
