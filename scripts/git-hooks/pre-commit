#!/bin/sh
# CYNIC — Pre-commit gate (Layer 2 enforcement, agnostic)
# L2 coord check → security → fmt. Fast (<2s total).
# Heavy gates (clippy, test, lint-rules) run once at pre-push via `make check`.

# Required: Rust 1.94.1 compiler bug (A1 debt, LLVM SIGSEGV in rmcp)
# See CLAUDE.md § VII: Build Environment
export RUST_MIN_STACK=67108864

# ── L2: Staged secret / real infra leak check ──
# Blocks obvious credential leaks and real Tailscale IPs anywhere in the staged diff,
# not just in Rust files. This catches config/docs regressions before they reach the repo.
security_check() {
    STAGED_ADDED=$(git diff --cached --no-color --unified=0 2>/dev/null | grep '^+' | grep -v '^+++' || true)
    [ -z "$STAGED_ADDED" ] && return 0
    FILTERED_ADDED=$(printf '%s\n' "$STAGED_ADDED" \
        | grep -v 'RAW_SECRETS=' \
        | grep -v 'HARDCODED_CREDS=' \
        | grep -v 'REAL_INFRA=' \
        | grep -v 'grep -iE .*api\[_-\]?key' \
        | grep -v 'grep -iE .*AIza' \
        | grep -v 'grep -E .*100\\\.' \
        | grep -v 'grep -vE.*Fungible' \
        | grep -v 'grep -vE.*api.key' || true)
    [ -z "$FILTERED_ADDED" ] && return 0

    RAW_SECRETS=$(printf '%s\n' "$FILTERED_ADDED" \
        | grep -iE 'AIza[[:alnum:]_-]{10,}|hf_[[:alnum:]_-]{10,}|sk-[[:alnum:]_-]{10,}' || true)
    HARDCODED_CREDS=$(printf '%s\n' "$FILTERED_ADDED" \
        | grep -iE '(api[_-]?key|token|password|secret)[^[:alnum:]]*[:=][[:space:]]*["'"'"']?[^$<[:space:]][^"'"'"'[:space:]]{6,}' \
        | grep -viE 'change-me|your-api-key-here|example|placeholder|dummy|fake|test-key|redacted|CancellationToken|\.api_key|ApplicationSecret|read_application_secret|\.token\(\)|client_secret:\s*PathBuf|let\s+token\s*=\s*self\.' \
        | grep -vE '\$\{[A-Z0-9_]+\}' \
        | grep -vE 'format!\(.*\{api_key\}' \
        | grep -vE 'f".*\{api_key\}' \
        | grep -vE 'os\.(environ\.get|getenv)\(' \
        | grep -vE 'process\.env\.' \
        | grep -vE 'std::env::var' \
        | grep -vE 'load_helius_key\(\)' \
        | grep -vE 'api_key[=:]\s*[a-z_]+[.,)]' \
        | grep -vE 'api-key=\{[a-z_]+\}' \
        | grep -vE 'healthy_token:|moderate_risk:|high_risk_rug:' \
        | grep -vE ':\s*Option<|:\s*Result<|:\s*Vec<|:\s*String' \
        | grep -vE '\.split\(.*api[_-]?key' \
        | grep -vE 'token::(parse|score)|mod token;|token:(revoked|active|unk)' \
        | grep -vE 'Token:\s+[A-Za-z0-9$]+\.\s+Type:\s*Fungible' \
        | grep -vE 'def\s+__init__.*token.*:' \
        | grep -vE '(token|secret|password|credentials)\s*:\s*(Optional|str|int|bool|None)' \
        | grep -vE '(endpoint_token|bot_token|access_token)\s*=' \
        | grep -vE 'ManualCorpusCollector\(' \
        | grep -vE 'api_key\s*=\s*get_api_key\(' \
        | grep -vE 'let\s+(mut\s+)?api_key\s*=' \
        | grep -vE 'let\s+(mut\s+)?token\s*=\s*(json|self|resp|response)' \
        | grep -vE 'token: different|token: extract|token: \w+ \w+ \w+' || true)
    if [ -n "$RAW_SECRETS$HARDCODED_CREDS" ]; then
        echo "SECURITY FAIL: possible secrets in staged changes:"
        [ -n "$RAW_SECRETS" ] && echo "$RAW_SECRETS"
        [ -n "$HARDCODED_CREDS" ] && echo "$HARDCODED_CREDS"
        return 1
    fi

    REAL_INFRA=$(printf '%s\n' "$FILTERED_ADDED" \
        | grep -E '100\.(74|75|119)\.[0-9]{1,3}\.[0-9]{1,3}' || true)
    if [ -n "$REAL_INFRA" ]; then
        echo "SECURITY FAIL: real Tailscale IPs in staged changes:"
        echo "$REAL_INFRA"
        return 1
    fi

    return 0
}
security_check || exit 1

# ── SSOT: block runtime state claims in static documents ──
# Constitution ≠ dashboard. Runtime state in .md files is stale by definition.
# Probe /health for live state. Never write it in docs.
ssot_check() {
    STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)
    [ -z "$STAGED_MD" ] && return 0
    STAGED_MD_DIFF=$(git diff --cached --no-color --unified=0 -- $STAGED_MD 2>/dev/null | grep '^+' | grep -v '^+++' || true)
    [ -z "$STAGED_MD_DIFF" ] && return 0
    # Match patterns that embed runtime state in static docs
    # Exclude: API.md (contract), CHANGELOG.md (history), rules/ (principles with examples)
    STALE_STATE=$(printf '%s\n' "$STAGED_MD_DIFF" \
        | grep -iE '^\+.*(Current state.*observed|Status:.*LIVE|Status:.*DEPLOYED|Status:.*COMPILED|Last updated:.*2026|as of 2026)' \
        | grep -viE 'CHANGELOG|API\.md|\.claude/rules/|status.*:|"status"' || true)
    if [ -n "$STALE_STATE" ]; then
        echo "SSOT WARNING: runtime state in static .md file:"
        echo "$STALE_STATE" | head -3
        echo ""
        echo "Constitution ≠ dashboard. Use POST /observe for dated state."
        echo "Bypass with: SSOT_OK=1 git commit"
        [ "${SSOT_OK:-}" = "1" ] && return 0
        return 1
    fi
    return 0
}
ssot_check || exit 1

# ── Branch warning: committing to main is usually a mistake ──
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo ""
    echo "WARNING: Committing directly to main. Consider:"
    echo "  git checkout -b feat/<scope>-$(date +%Y-%m-%d)"
    echo ""
fi

# ── L2: Coordination claim verification ──
# Checks that staged kernel files are not claimed by ANOTHER agent.
# Graceful: skips if kernel unreachable or no env. Does NOT block on unclaimed files.
coord_check() {
    . ~/.cynic-env 2>/dev/null || return 0
    KERNEL_ADDR="${CYNIC_REST_ADDR:-}"
    API_KEY="${CYNIC_API_KEY:-}"
    [ -z "$KERNEL_ADDR" ] && return 0
    [ -z "$API_KEY" ] && return 0
    command -v curl >/dev/null 2>&1 || return 0
    command -v jq >/dev/null 2>&1 || return 0

    # Get current agent ID (Claude hook format or fallback)
    MY_AGENT=$(echo "${CLAUDE_SESSION_ID:-${GEMINI_SESSION_ID:-${CODEX_SESSION_ID:-unknown}}}" | head -c 20)

    STAGED_KERNEL=$(git diff --cached --name-only --diff-filter=ACM | grep '^cynic-kernel/' || true)
    [ -z "$STAGED_KERNEL" ] && return 0

    # Fetch active claims
    CLAIMS_JSON=$(curl -s --connect-timeout 2 --max-time 3 \
        "http://${KERNEL_ADDR}/agents" \
        -H "Authorization: Bearer $API_KEY" 2>/dev/null || echo '{}')

    for file in $STAGED_KERNEL; do
        target="${file#cynic-kernel/}"
        # Check if this file is claimed by a DIFFERENT agent
        holder=$(echo "$CLAIMS_JSON" | jq -r \
            --arg t "$target" \
            '.claims[]? | select(.target == $t and .active == true) | .agent_id' 2>/dev/null || true)
        if [ -n "$holder" ]; then
            case "$holder" in
                *"$MY_AGENT"*) ;; # our own claim — OK
                *)
                    echo "COORD CONFLICT: '$file' is claimed by '$holder'."
                    echo "Release the claim or coordinate before committing."
                    echo "  curl -X POST http://${KERNEL_ADDR}/coord/who"
                    return 1
                    ;;
            esac
        fi
    done
    return 0
}
coord_check || exit 1

# ── Cargo.lock coherence check ──
# If Cargo.toml changed, verify lock is consistent WITHOUT upgrading deps.
# cargo update --locked fails if lock needs regeneration but doesn't modify it.
# Catches phantom diffs without pulling breaking upgrades (rmcp 1.2→1.5 incident).
STAGED_TOML=$(git diff --cached --name-only | grep 'Cargo\.toml$' || true)
if [ -n "$STAGED_TOML" ]; then
    if command -v cargo >/dev/null 2>&1; then
        if ! cargo check --locked 2>/dev/null; then
            echo "LOCKFILE DRIFT: Cargo.lock inconsistent with Cargo.toml."
            echo "  Run: cargo update && git add Cargo.lock"
            echo "  WARNING: cargo update may pull breaking dep upgrades. Pin versions if needed."
            exit 1
        fi
    fi
fi

# Skip if no .rs files are staged (docs-only commits don't need checks)
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -z "$STAGED_RS" ]; then
    exit 0
fi

# Skip on merge commits (auto-generated, already validated)
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    exit 0
fi

# Fast fail: format check (<1s)
cargo fmt -p cynic-kernel -- --check || { echo "Run 'cargo fmt' to fix formatting."; exit 1; }

# clippy + test run at pre-push (make check). No duplication here.
