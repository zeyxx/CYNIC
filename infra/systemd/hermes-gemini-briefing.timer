[Unit]
Description=CYNIC Hermes Gemini Briefing ‚Äî synthesizes domain wisdom every 4 hours
Documentation=https://github.com/zeyxx/CYNIC/docs/hermes-architecture.md
# After=cynic-kernel.service ‚Äî REMOVED: causes ordering cycle (timers.target‚Üítimer‚Üíkernel‚Üíbasic‚Üítimers.target)
# The SERVICE has After=cynic-kernel.service which handles the dependency.

[Timer]
OnBootSec=10min
OnUnitActiveSec=4h
Persistent=true

[Install]
WantedBy=timers.target
