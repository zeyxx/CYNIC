{
  "version": "1.0.0",
  "nodes": [
    {
      "name": "cynic-forge",
      "role": "proxmox_host_kernel",
      "os": "Proxmox VE 8.2",
      "network": {
        "local": "192.168.0.37",
        "tailscale": "<TAILSCALE_FORGE>"
      },
      "services": [
        {
          "name": "llama-embed",
          "port": 8081,
          "description": "Sovereign embedding backend (Qwen3-Embed)"
        },
        {
