#!/usr/bin/env bash
# CYNIC pre-push — sovereign CI gate + branch discipline
# No cloud CI, no GitHub Actions, no external dependency.
# The machine that pushes is the machine that verifies.
# Universal: protects against all agents (Claude, Gemini, human).
#
# Runs the FULL make check pipeline:
#   fmt → clippy → test → lint-rules → lint-drift → lint-security → audit
# If any gate fails, push is blocked. No exceptions.
#
# Also: blocks direct push to `main` — protected branch on origin requires
# PR flow (GH006). Fail early and explain, instead of letting the user wait
# through the gate only to be rejected by GitHub.
set -euo pipefail

# Git passes refs via stdin: "<local_ref> <local_sha> <remote_ref> <remote_sha>\n".
# Read all lines, check for main pushes, detect deletions.
ZERO_SHA="0000000000000000000000000000000000000000"
IS_DELETE=true  # assume delete until we see a non-zero local SHA
while IFS= read -r line; do
    local_sha=$(printf '%s\n' "$line" | awk '{print $2}')
    remote_ref=$(printf '%s\n' "$line" | awk '{print $3}')
    # If any ref has a non-zero local SHA, it's not a pure delete
    if [ "$local_sha" != "$ZERO_SHA" ]; then
        IS_DELETE=false
    fi
    if [ "$remote_ref" = "refs/heads/main" ]; then
        echo ""
        echo "✗ Direct push to main is blocked — protected branch workflow."
        echo ""
        echo "  Flow:"
        echo "    git checkout -b <type>/<scope>-$(date +%Y-%m-%d)"
        echo "    git push -u origin <branch>"
        echo "    gh pr create --base main"
        echo ""
        echo "  See .claude/rules/workflow.md § Branch-PR discipline."
        exit 1
    fi
done

# Skip CI gate for branch deletions (git push --delete)
if [ "$IS_DELETE" = "true" ]; then
    exit 0
fi

source ~/.cargo/env 2>/dev/null || true
export RUST_MIN_STACK=${RUST_MIN_STACK:-67108864}

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

echo "══════════════════════════════════════════"
echo "  CYNIC pre-push — sovereign CI gate"
echo "══════════════════════════════════════════"
echo ""

# ── Freshness check (A8 metabolic optimization) ──
# If the test binary is newer than all source files, skip recompilation.
# This avoids the KC5 kill chain: cortex already validated → pre-push re-validates.
# RTK data (2026-04-26): 449 min spent in make check, much of it redundant.
NEWEST_SRC=$(find cynic-kernel/src -name '*.rs' -exec stat -c '%Y' {} + 2>/dev/null | sort -rn | head -1)
TEST_BIN=$(find target/debug/deps -name 'cynic_kernel-*' -executable 2>/dev/null | head -1)

if [ -n "$TEST_BIN" ] && [ -n "$NEWEST_SRC" ]; then
    BIN_TIME=$(stat -c '%Y' "$TEST_BIN" 2>/dev/null || echo 0)
    SRC_TIME="$NEWEST_SRC"
    if [ "$BIN_TIME" -gt "$SRC_TIME" ]; then
        echo "  ⚡ Build artifacts are fresh (newer than source)."
        echo "  Running lint-rules + lint-drift only (skip recompilation)."
        echo ""
        make lint-rules && make lint-drift
        echo ""
        # Config drift check
        echo "▶ Config drift check..."
        scripts/config-sync.sh check
        echo ""
        echo "══════════════════════════════════════════"
        echo "  ✓ Fresh artifacts + lint gates passed"
        echo "══════════════════════════════════════════"
        exit 0
    fi
fi

# ── Gate marker check (decouples heavy CI from SSH connection) ──
# The full `make check` takes ~3 min (build + 704 tests + clippy + audit).
# Running it HERE holds the SSH connection open → timeout kills the push.
# Fix: require `make gate` BEFORE `git push`. The marker proves it passed.
GATE_MARKER="$PROJECT_DIR/.gate-passed"

if [ -f "$GATE_MARKER" ]; then
    GATE_TIME=$(stat -c '%Y' "$GATE_MARKER" 2>/dev/null || echo 0)

    # Ignore auto-generated files that `make gate` produces (they don't invalidate the marker)
    AUTO_GENERATED="TOPOLOGY.md target/ .gate-passed"
    MODIFIED_REAL=$(git status --porcelain 2>/dev/null | grep -v '^ D' | awk '{print $NF}' | grep -v -E "^($AUTO_GENERATED|external/CultScreener)" || true)

    if [ -z "$MODIFIED_REAL" ]; then
        # No real source changes since last commit — gate marker freshness is what matters
        if [ -n "$NEWEST_SRC" ] && [ "$GATE_TIME" -gt "$NEWEST_SRC" ]; then
            echo "  ⚡ Gate marker is fresh (make gate passed, no real source changes)."
            echo "  Running lightweight checks only..."
            echo ""
            make lint-rules && make lint-drift
            echo ""
            echo "▶ Config drift check..."
            scripts/config-sync.sh check
        else
            echo ""
            echo "  ✗ Gate marker is STALE (source changed after last make gate)."
            echo "  Run: make gate"
            echo "  Then: git push"
            exit 1
        fi
    else
        # Real source changes detected (not just auto-generated files)
        echo ""
        echo "  ✗ Source changes detected since last gate:"
        echo "$MODIFIED_REAL"
        echo ""
        echo "  Run: make gate"
        echo "  Then: git push"
        exit 1
    fi
else
    echo ""
    echo "  ✗ No gate marker found. Run the full CI gate first:"
    echo "  Run: make gate"
    echo "  Then: git push"
    exit 1
fi

# ── Agent Protocol checks (LOCAL only — zero network calls) ──
# Network checks (gh pr list, git fetch, coord/who) moved to `make gate`.
# Pre-push must NEVER open network connections — the SSH transport is already
# open and additional connections cause interference/timeouts (R24 incident).
echo ""
echo "▶ Agent Protocol checks (local)..."

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Local check: branch must not be a stale merged branch (uses local refs only)
if git log --oneline origin/main..HEAD 2>/dev/null | head -1 | grep -q '^$'; then
    echo "  ⚠ No commits ahead of origin/main — nothing to push"
fi

echo "  ✓ Local checks passed"

echo ""
echo "══════════════════════════════════════════"
echo "  ✓ All gates passed — push allowed"
echo "══════════════════════════════════════════"
