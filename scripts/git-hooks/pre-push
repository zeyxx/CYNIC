#!/usr/bin/env bash
# CYNIC pre-push — sovereign CI gate + branch discipline
# No cloud CI, no GitHub Actions, no external dependency.
# The machine that pushes is the machine that verifies.
# Universal: protects against all agents (Claude, Gemini, human).
#
# Runs the FULL make check pipeline:
#   fmt → clippy → test → lint-rules → lint-drift → lint-security → audit
# If any gate fails, push is blocked. No exceptions.
#
# Also: blocks direct push to `main` — protected branch on origin requires
# PR flow (GH006). Fail early and explain, instead of letting the user wait
# through the gate only to be rejected by GitHub.
set -euo pipefail

# Detect pushes to main and fail fast with remediation instructions.
# Git passes refs via stdin: "<local_ref> <local_sha> <remote_ref> <remote_sha>\n".
while IFS= read -r line; do
    remote_ref=$(printf '%s\n' "$line" | awk '{print $3}')
    if [ "$remote_ref" = "refs/heads/main" ]; then
        echo ""
        echo "✗ Direct push to main is blocked — protected branch workflow."
        echo ""
        echo "  Flow:"
        echo "    git checkout -b <type>/<scope>-$(date +%Y-%m-%d)"
        echo "    git push -u origin <branch>"
        echo "    gh pr create --base main"
        echo ""
        echo "  See .claude/rules/workflow.md § Branch-PR discipline."
        exit 1
    fi
done

source ~/.cargo/env 2>/dev/null || true
export RUST_MIN_STACK=${RUST_MIN_STACK:-67108864}

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

echo "══════════════════════════════════════════"
echo "  CYNIC pre-push — sovereign CI gate"
echo "══════════════════════════════════════════"
echo ""

# ── Freshness check (A8 metabolic optimization) ──
# If the test binary is newer than all source files, skip recompilation.
# This avoids the KC5 kill chain: cortex already validated → pre-push re-validates.
# RTK data (2026-04-26): 449 min spent in make check, much of it redundant.
NEWEST_SRC=$(find cynic-kernel/src -name '*.rs' -exec stat -c '%Y' {} + 2>/dev/null | sort -rn | head -1)
TEST_BIN=$(find target/debug/deps -name 'cynic_kernel-*' -executable 2>/dev/null | head -1)

if [ -n "$TEST_BIN" ] && [ -n "$NEWEST_SRC" ]; then
    BIN_TIME=$(stat -c '%Y' "$TEST_BIN" 2>/dev/null || echo 0)
    SRC_TIME="$NEWEST_SRC"
    if [ "$BIN_TIME" -gt "$SRC_TIME" ]; then
        echo "  ⚡ Build artifacts are fresh (newer than source)."
        echo "  Running lint-rules + lint-drift only (skip recompilation)."
        echo ""
        make lint-rules && make lint-drift
        echo ""
        echo "══════════════════════════════════════════"
        echo "  ✓ Fresh artifacts + lint gates passed"
        echo "══════════════════════════════════════════"
        exit 0
    fi
fi

echo "  Building from source (artifacts stale or missing)..."
echo ""

# Full pipeline — same as make check
make check

echo ""
echo "══════════════════════════════════════════"
echo "  ✓ All gates passed — push allowed"
echo "══════════════════════════════════════════"
