# CYNIC Python Kernel — Environment Variables
# Copy this file to .env and fill in your values
# "φ distrusts φ" — κυνικός

# ==============================================================================
# Database
# ==============================================================================
POSTGRES_USER=cynic
POSTGRES_PASSWORD=cynic_dev
POSTGRES_DB=cynic

# Connection string (auto-built from above, or override)
# CYNIC_DATABASE_URL=postgresql://cynic:cynic_dev@postgres:5432/cynic

# ==============================================================================
# LLM Configuration
# ==============================================================================
# Ollama (local, free) — PRIMARY
OLLAMA_URL=http://ollama:11434
OLLAMA_NUM_PARALLEL=4

# Claude API (optional, for MACRO cycle reasoning)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Gemini API (optional, for consensus validation)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ==============================================================================
# Optional: Local models directory
# ==============================================================================
# If you have GGUF model files in a local directory, mount them:
# CYNIC_MODELS_DIR=/models

# ==============================================================================
# Llama.cpp (GPU acceleration)
# ==============================================================================
# Number of GPU layers (-1 = all, 0 = CPU only)
# LLAMA_CPP_GPU_LAYERS=-1
# Number of CPU threads
# LLAMA_CPP_THREADS=8

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL=INFO

# ==============================================================================
# Development
# ==============================================================================
# PYTHONUNBUFFERED=1
