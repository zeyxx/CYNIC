# CYNIC Configuration Template
# Copy to .env and fill in values for your environment
# All configuration options read here — no scattered defaults elsewhere.

# ============================================
# DISCORD BOT CONFIGURATION
# ============================================

# Discord bot token (required for Discord bot)
CYNIC_DISCORD_TOKEN=your-discord-token-here

# Optional: Discord application/guild ID for dev testing
CYNIC_DISCORD_GUILD_ID=

# ============================================
# TELEGRAM BOT CONFIGURATION (Optional)
# ============================================

# Telegram bot token (optional, if Telegram bot enabled)
CYNIC_TELEGRAM_TOKEN=

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database URL (SQLite, PostgreSQL, etc)
# Format: driver://user:password@host:port/database
# Default: SQLite in current directory
CYNIC_DATABASE_URL=sqlite:///cynic.db

# ============================================
# JUDGMENT & GOVERNANCE SETTINGS
# ============================================

# Maximum judgments to process in a single batch
CYNIC_MAX_JUDGMENTS_BATCH=10

# Judgment timeout (seconds) - max time for judge to decide
CYNIC_JUDGMENT_TIMEOUT_SECONDS=30

# Number of Dogs to use in consensus (1-11, default 11)
CYNIC_NUM_DOGS=11

# ============================================
# LEARNING & Q-TABLE SETTINGS
# ============================================

# Learning rate for Q-Table updates (0-1, default 0.1)
CYNIC_LEARNING_RATE=0.1

# Q-Table discount factor (0-1, default 0.99)
CYNIC_DISCOUNT_FACTOR=0.99

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment (development, staging, production)
CYNIC_ENVIRONMENT=development

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
CYNIC_LOG_LEVEL=INFO

# Log file path (optional, defaults to stdout)
CYNIC_LOG_FILE=

# Debug mode (true/false)
CYNIC_DEBUG=false

# ============================================
# ADVANCED SETTINGS
# ============================================

# Consensus algorithm timeout (milliseconds)
CYNIC_CONSENSUS_TIMEOUT_MS=5000

# E-Score reputation decay rate (0-1, default 0.95)
CYNIC_E_SCORE_DECAY=0.95

# Memory limit for judgment buffer (max entries)
CYNIC_JUDGMENT_BUFFER_MAX=89
