# CYNIC Fleet Topology — copy to ~/.config/cynic/fleet.toml and fill in values.
# Source of truth for machine topology. Never commit real IPs.
#
# Convention: [machine.X] sections are read by scripts/fleet-gen.py.
# Placeholder mapping: machine key suffix (after last hyphen) → <TAILSCALE_{SUFFIX}>
#   machine.cynic-core → <TAILSCALE_CORE>
#   machine.cynic-gpu  → <TAILSCALE_GPU>
#   machine.kairos     → <TAILSCALE_KAIROS>

[machine.cynic-core]
tailscale_ip = "<TAILSCALE_CORE>"
os = "linux"
ssh_user = "user"
ssh_key = "~/.ssh/id_ed25519"
role = "kernel, db, cpu-inference"
status = "active"

[machine.cynic-gpu]
tailscale_ip = "<TAILSCALE_GPU>"
os = "windows"
ssh_user = "your-windows-user"
ssh_key = "~/.ssh/id_ed25519"
role = "gpu-inference"
status = "active"

# Offline machines — uncomment when brought back online.
# [machine.kairos]
# tailscale_ip = "<TAILSCALE_KAIROS>"
# os = "linux"
# ssh_user = "kairos"
# ssh_key = "~/.ssh/kairos_proxmox"
# role = "project-kairos"
# status = "offline"

# ── Port Map ───────────────────────────────────────────────────
# 3030  cynic-kernel REST API (Tailscale only)
# 8000  SurrealDB (localhost only — never exposed)
# 8080  llama-server inference (Tailscale only)
# 8081  llama-embed embedding (Tailscale only)

# ── Dependencies (restart order) ──────────────────────────────
# 1. surrealdb        → systemctl --user restart surrealdb
# 2. cynic-kernel     → systemctl --user restart cynic-kernel
# 3. llama-server     → systemctl --user restart llama-server
# 4. llama-embed      → systemctl --user restart llama-embed
# Wait 5s between restarts. Verify with `make status`.
