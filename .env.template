# 🧬 CYNIC ORGANISM CONFIGURATION TEMPLATE
# Copy this to .env and fill in your secrets.

# --- 1. TELEGRAM VOICE (Primary) ---
# Used for anomaly alerts and learning notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- 2. AI & LLM ADAPTERS ---
# At least one is recommended for MACRO consciousness
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
# Local fallback (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# --- 3. STORAGE (SurrealDB) ---
SURREAL_URL=ws://localhost:8080/rpc
SURREAL_USER=root
SURREAL_PASS=local_dev_only
SURREAL_NS=cynic
SURREAL_DB=cynic

# --- 4. SOLANA & MARKET ---
# Required for real-time financial perception
HELIUS_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- 5. INFRASTRUCTURE & DEVOPS ---
CYNIC_ENVIRONMENT=development  # development | production
CYNIC_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
PORT=58765                     # API Port
CYNIC_INSTANCE_ID=             # Optional: will be auto-generated if empty
CYNIC_STATE_DIR=~/.cynic       # Where to store checkpoints

# --- 6. PHI-BOUNDED PARAMETERS (Experts only) ---
# Most are derived from PHI by default
CYNIC_LEARNING_RATE=0.038      # PHI^-7 (approx)
CYNIC_DISCOUNT_FACTOR=0.382    # PHI^-2
CYNIC_MAX_JUDGMENTS_BATCH=13   # F(7)
CYNIC_CONSENSUS_TIMEOUT_MS=5000
