{
  "version": "1.1.0",
  "nodes": [
    {
      "name": "cynic-forge",
      "role": "proxmox_host_kernel",
      "os": "Proxmox VE 8.2",
      "network": {
        "local": "192.168.0.37",
        "tailscale": "<TAILSCALE_FORGE>"
      },
      "vms": [
        {
          "id": "lxc/100",
          "name": "headscale",
          "ip": "192.168.0.40"
        },
        {
          "id": "lxc/101",
          "name": "forgejo",
          "ip": "192.168.0.41"
        },
        {
          "id": "qemu/102",
          "name": "cynic-node-forge",
          "ip": "192.168.0.42"
        }
      ],
      "services": [
        {
          "name": "llama-embed",
          "port": 8081,
          "description": "Sovereign embedding backend (Qwen3-Embed)"
        },
        {
          "name": "surrealdb-replica",
          "port": 8001,
          "description": "Failover storage node"
        }
      ],
      "status": "active"
    },
    {
      "name": "cynic-gpu",
      "role": "inference_node",
      "network": {
        "local": "192.168.0.67",
        "tailscale": "100.64.0.5"
      },
      "status": "active"
    },
    {
      "name": "ubuntu",
      "role": "cortex_host",
      "network": {
        "local": "192.168.0.12",
        "tailscale": "100.64.0.1"
      },
      "status": "active"
    }
  ],
  "routing_rules": {
    "primary_tunnel": "tailscale_100_64_0_0_24",
    "management_fallback": "local_192_168_0_0_24"
  },
  "organs": [
    {
      "name": "organ-anvil",
      "instance": "organ-anvil-hermes-agent",
      "role": "repo_lifecycle_manager",
      "description": "Git repo hygiene, branch health, claim hygiene, and lifecycle triage.",
      "scope": "github+forgejo",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    },
    {
      "name": "organ-docker",
      "instance": "organ-docker-hermes-agent",
      "role": "container_surface_manager",
      "description": "Local container fallback operator surface and portal reproducibility manager.",
      "scope": "local+tailscale",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    },
    {
      "name": "organ-vercel",
      "instance": "organ-vercel-hermes-agent",
      "role": "deployment_surface_manager",
      "description": "Public edge deployment manager for CYNIC frontends and Talaria surfaces.",
      "scope": "vercel+github_deployments",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    },
    {
      "name": "organ-telegram",
      "instance": "organ-telegram-hermes-agent",
      "role": "messaging_surface_manager",
      "description": "Telegram runtime and public/ops messaging surface manager.",
      "scope": "telegram+ops+public",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    },
    {
      "name": "organ-x",
      "instance": "organ-x-hermes-agent",
      "role": "x_surface_manager",
      "description": "X/Twitter perception, curation, and posting surface manager.",
      "scope": "x+curation+alerts",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    },
    {
      "name": "organ-jupyter",
      "instance": "organ-jupyter-hermes-agent",
      "role": "notebook_surface_manager",
      "description": "Jupyter Notebook / Data Science environment manager for exploratory coding and data analysis within the CYNIC ecosystem.",
      "scope": "local+jupyterlab",
      "cron": "every 30min",
      "status": "active",
      "depends_on": [
        "cynic-kernel"
      ],
      "coord": "cynic_coord_register/release"
    }
  ]
}
