[Unit]
Description=CYNIC Hermes Agent Executor — autonomous meta-agent task runner
After=cynic-kernel.service hermes-x-ingest.service
Wants=hermes-x-ingest.service

[Service]
Type=simple
EnvironmentFile=-/root/.config/cynic/env
EnvironmentFile=-/root/.cynic-env
ExecStart=/usr/bin/python3 /root/Bureau/CYNIC/scripts/hermes-x/hermes_agent_task_executor.py --organ-dir /root/.cynic/organs/hermes/x
Restart=on-failure
RestartSec=30s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
