[Unit]
Description=CYNIC Hermes Agent Executor — autonomous meta-agent task runner
After=cynic-kernel.service hermes-x-ingest.service
Wants=hermes-x-ingest.service

[Service]
Type=simple
EnvironmentFile=%h/.config/cynic/env
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HERMES_AGENT_DOMAIN_DENY=organ-anvil,repo-lifecycle
ExecStart=/usr/bin/python3 %h/Bureau/CYNIC/scripts/hermes-x/core/hermes_agent_task_executor.py --organ-dir %h/.cynic/organs/hermes/x
Restart=on-failure
RestartSec=30s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
