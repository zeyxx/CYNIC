[Unit]
Description=CYNIC Hermes behavior logger — mouse/keyboard capture for ML training
After=hermes-browser.service
StartLimitIntervalSec=300
StartLimitBurst=3

[Service]
Type=simple
Environment=DISPLAY=:0
ExecStart=%h/.cynic/organs/hermes/behavior/.venv/bin/python %h/cynic/scripts/hermes-x/core/behavior_logger.py
Restart=on-failure
RestartSec=10
# Cgroup limits — observed: 32MB.
MemoryMax=128M

[Install]
WantedBy=default.target
