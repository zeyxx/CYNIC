[Unit]
Description=CYNIC Organ Vercel Cron - dispatch deployment surface task
After=cynic-kernel.service organ-vercel-hermes-agent.service
Wants=organ-vercel-hermes-agent.service

[Service]
Type=oneshot
WorkingDirectory=%h/Bureau/CYNIC
EnvironmentFile=%h/.config/cynic/env
ExecStart=/usr/bin/python3 %h/Bureau/CYNIC/scripts/organ-vercel-dispatch.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
