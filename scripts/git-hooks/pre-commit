#!/bin/sh
# CYNIC — Pre-commit gate (Layer 2 enforcement, agnostic)
# fmt (fast, <1s) → clippy (debug mode, 5-15s incremental).
# Full test suite + release build runs via `make check` before deploy.

# Skip if no .rs files are staged (docs-only commits don't need checks)
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -z "$STAGED_RS" ]; then
    exit 0
fi

# Skip on merge commits (auto-generated, already validated)
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    exit 0
fi

# Fast fail: format check (<1s)
cargo fmt -p cynic-kernel -- --check || { echo "Run 'cargo fmt' to fix formatting."; exit 1; }

# Lint check (5-15s incremental, debug mode — same lints as release)
exec cargo clippy --workspace -- -D warnings
