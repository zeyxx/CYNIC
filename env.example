# CYNIC Environment — copy to ~/.cynic-env and fill in values.
# Source of truth for secrets (Rule 12). Never commit real values.
#
# This is the source of truth (Rule 12). Scripts and hooks source this directly.
# For systemd: generate ~/.config/cynic/env with: sed 's/^export //' ~/.cynic-env > ~/.config/cynic/env
# systemd does NOT support `export` prefix — the generated file strips it.

# Kernel API authentication (required)
export CYNIC_API_KEY="change-me-to-a-random-string"
# Local dev escape hatch only: allows REST to start without Bearer auth.
# Never use this in shared or production environments.
# export CYNIC_ALLOW_OPEN_API="1"

# Kernel listen address (required)
export CYNIC_REST_ADDR="127.0.0.1:3030"

# SurrealDB (required for persistence — kernel runs without it but verdicts won't persist)
export SURREALDB_PASS="change-me"
# Optional overrides (defaults in backends.toml or code):
# export SURREALDB_URL="http://localhost:8000"
# export SURREALDB_NS="cynic"
# export SURREALDB_DB="v2"

# LLM backends — configure in ~/.config/cynic/backends.toml
# API keys for cloud Dogs (only if using them):
# export GEMINI_API_KEY="your-gemini-key"
# export HF_API_KEY="your-huggingface-key"

# Summarizer endpoint (optional — enables session memory injection into Dog prompts)
# export CYNIC_SUMMARIZER_URL="http://localhost:8080"
