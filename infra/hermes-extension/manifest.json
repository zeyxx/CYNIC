{
  "manifest_version": 3,
  "name": "CYNIC Hermes Tracker",
  "version": "1.0.0",
  "description": "Captures organic X.com engagement as ground truth for Hermes.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "http://localhost:3030/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
