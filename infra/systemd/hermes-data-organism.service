[Unit]
Description=Hermes Data Organism — Continuous perception, analysis, reflection
After=network.target

[Service]
Type=oneshot
WorkingDirectory=%h/cynic
EnvironmentFile=%h/.config/cynic/env

# Perception cycle: ingest session logs, kernel observations, node data
ExecStart=/usr/bin/python3 scripts/hermes_data_organism.py

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes-data-organism

# Resource limits
MemoryMax=256M
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
