{
  "_doc": "Module isolation zones for multi-cortex dispatch. Each zone is a set of paths that one cortex can claim exclusively. domain/mod.rs is the DMZ — only one cortex per session.",
  "zones": {
    "api": {
      "paths": ["cynic-kernel/src/api/"],
      "description": "REST + MCP + WebSocket handlers",
      "coupling": "reads domain types (leaf — nothing imports api)"
    },
    "storage": {
      "paths": ["cynic-kernel/src/storage/"],
      "description": "Memory + SurrealDB adapters",
      "coupling": "reads domain types, imported by pipeline"
    },
    "infra": {
      "paths": ["cynic-kernel/src/infra/"],
      "description": "Probes, tasks, health, runtime loops",
      "coupling": "reads domain types, imported by 7 files"
    },
    "pipeline": {
      "paths": ["cynic-kernel/src/pipeline/"],
      "description": "Judge pipeline orchestration",
      "coupling": "reads domain + storage"
    },
    "domain-ccm": {
      "paths": ["cynic-kernel/src/domain/ccm/"],
      "description": "Crystal Coherence Machine",
      "coupling": "independent submodule (2 cross-imports)"
    },
    "domain-core": {
      "paths": ["cynic-kernel/src/domain/"],
      "description": "Core types — DMZ, max 1 cortex",
      "coupling": "imported by everything — collision hub",
      "max_cortex": 1
    },
    "node": {
      "paths": ["cynic-node/"],
      "description": "Separate crate — zero kernel coupling",
      "coupling": "none"
    },
    "docs": {
      "paths": ["docs/", "API.md", "CLAUDE.md", "AGENTS.md"],
      "description": "Documentation and constitution",
      "coupling": "none (text only)"
    },
    "hooks": {
      "paths": [".claude/hooks/", ".claude/rules/", ".claude/agents/"],
      "description": "Claude Code hooks, rules, agent defs",
      "coupling": "none (shell/config only)"
    },
    "scripts": {
      "paths": ["scripts/", "infra/"],
      "description": "Deployment, systemd, tooling",
      "coupling": "none (shell/config only)"
    },
    "python": {
      "paths": ["cynic-python/"],
      "description": "Python tier-2 infrastructure",
      "coupling": "none (separate runtime)"
    }
  }
}
