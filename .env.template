# =============================================================================
# CYNIC Governance Bot - Configuration Template
# =============================================================================
# Copy this file to .env and fill in the required values
# For development, use the defaults. For production, all values must be set.
#
# Environment: development | staging | production
# =============================================================================

# =============================================================================
# DISCORD BOT (REQUIRED)
# =============================================================================
# Get your Discord bot token from: https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
DISCORD_PREFIX=/

# =============================================================================
# CYNIC INTEGRATION
# =============================================================================
# CYNIC organism and MCP server URLs
CYNIC_URL=http://127.0.0.1:8765
CYNIC_MCP_ENABLED=true
CYNIC_MCP_URL=http://127.0.0.1:8766
CYNIC_TIMEOUT_SECONDS=30
CYNIC_RETRY_COUNT=3

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (development):
#   DATABASE_URL=sqlite:///governance_bot.db
#
# PostgreSQL (production):
#   DATABASE_URL=postgresql://user:password@localhost:5432/governance
#
DATABASE_URL=sqlite:///governance_bot.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=3600
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_DIR=./backups

# =============================================================================
# COMMUNITY DEFAULTS
# =============================================================================
# These values are used when creating new communities
COMMUNITY_VOTING_PERIOD_HOURS=72
COMMUNITY_EXECUTION_DELAY_HOURS=24
COMMUNITY_QUORUM_PERCENTAGE=25
COMMUNITY_APPROVAL_THRESHOLD_PERCENTAGE=50
COMMUNITY_PROPOSAL_SUBMISSION_FEE=100
COMMUNITY_MIN_DOGS_CONSENSUS=6

# =============================================================================
# FEATURES
# =============================================================================
# Enable/disable specific features
FEATURES_GASDF_ENABLED=true
FEATURES_NEAR_EXECUTION_ENABLED=false
FEATURES_LEARNING_LOOP_ENABLED=true
FEATURES_AGENT_MEMBERS_ENABLED=false

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOGGING_LEVEL=INFO
LOGGING_FILE=governance_bot.log
LOGGING_FILE_ENABLED=true
LOGGING_MAX_FILE_SIZE_MB=10
LOGGING_BACKUP_COUNT=5

# =============================================================================
# BOT RUNTIME
# =============================================================================
# environment: development | staging | production
BOT_ACTIVITY=governance decisions
BOT_STATUS=ACTIVE
BOT_ENVIRONMENT=development

# =============================================================================
# NEAR BLOCKCHAIN (if FEATURES_NEAR_EXECUTION_ENABLED=true)
# =============================================================================
# NEAR testnet account and contract addresses
# NEAR_ACCOUNT_ID=governance.testnet
# NEAR_PRIVATE_KEY=your_private_key_here
# NEAR_CONTRACT_ID=contract.governance.testnet
# NEAR_RPC_URL=https://rpc.testnet.near.org

# =============================================================================
# GASDF INTEGRATION (if FEATURES_GASDF_ENABLED=true)
# =============================================================================
# GASdf gasless transaction configuration
# GASDF_API_URL=https://api.gasdf.example.com
# GASDF_API_KEY=your_gasdf_api_key_here

# =============================================================================
# MONITORING & ALERTS (optional)
# =============================================================================
# Sentry error tracking (optional)
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
#
# Prometheus metrics (optional)
# PROMETHEUS_PORT=8000

# =============================================================================
# NOTES
# =============================================================================
# 1. DISCORD_TOKEN is REQUIRED - bot will not start without it
# 2. DATABASE_URL defaults to SQLite for development
# 3. For production, use PostgreSQL and set proper pool settings
# 4. Keep this file out of version control - use .env.local for overrides
# 5. Set BOT_ENVIRONMENT=production only in production
# 6. All numeric values have validation constraints - see config.py
# =============================================================================
