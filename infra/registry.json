{
  "version": "1.1.0",
  "nodes": [
    {
      "name": "cynic-forge",
      "role": "proxmox_host_kernel",
      "os": "Proxmox VE 8.2",
      "network": {
        "local": "192.168.0.37",
        "tailscale": "<TAILSCALE_FORGE>"
      },
      "vms": [
        {
          "id": "lxc/100",
          "name": "headscale",
          "ip": "192.168.0.40"
        },
        {
          "id": "lxc/101",
          "name": "forgejo",
          "ip": "192.168.0.41"
        },
        {
          "id": "qemu/102",
          "name": "cynic-node-forge",
          "ip": "192.168.0.42"
        }
      ],
      "services": [
        {
          "name": "llama-embed",
          "port": 8081,
          "description": "Sovereign embedding backend (Qwen3-Embed)"
        },
        {
          "name": "surrealdb-replica",
          "port": 8001,
          "description": "Failover storage node"
        }
      ],
      "status": "active"
    },
    {
      "name": "cynic-gpu",
      "role": "inference_node",
      "network": {
        "local": "192.168.0.67",
        "tailscale": "100.64.0.5"
      },
      "status": "active"
    },
    {
      "name": "ubuntu",
      "role": "cortex_host",
      "network": {
        "local": "192.168.0.12",
        "tailscale": "100.64.0.1"
      },
      "status": "active"
    }
  ],
  "routing_rules": {
    "primary_tunnel": "tailscale_100_64_0_0_24",
    "management_fallback": "local_192_168_0_0_24"
  },
  "organs": [
    {
      "name": "organ-anvil",
      "instance": "organ-anvil-hermes-agent",
      "role": "repo_lifecycle_manager",
      "description": "Git repo hygiene — branches, PRs, dirty trees, sync enforcement",
      "scope": "github+forgejo",
      "cron": "every 30min",
      "status": "active",
      "depends_on": ["cynic-kernel"],
      "coord": "cynic_coord_register/release"
    }
  ]
}
