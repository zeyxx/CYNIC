#!/bin/bash
set -e

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
export PYTHONPATH="${REPO_ROOT}:${PYTHONPATH}"

echo "🔍 Running pre-commit validation..."

# Gate 1: Encoding Validation
echo "  [1/5] Validating UTF-8 encoding..."
python scripts/validate_encoding.py || exit 1

# Gate 2: Import Analysis
echo "  [2/5] Checking for circular imports..."
python scripts/analyze_imports.py || exit 1

# Gate 3: Factory Audit
echo "  [3/5] Auditing factory wiring..."
python scripts/audit_factory_wiring.py || exit 1

# Gate 4: Code Complexity Analysis (WARNING only)
echo "  [4/5] Checking cyclomatic complexity (informational)..."
python scripts/check_complexity.py || echo "⚠️  Note: Complexity warnings above"

# Gate 5: Commit Message Format
echo "  [5/5] Validating commit message format..."
python scripts/validate_commit_message.py || exit 1

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║     ✅ PRE-COMMIT VALIDATION COMPLETE - READY TO PUSH    ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
echo "Note: Run unit tests locally with: python -m pytest tests/"
echo "      Update health report with: python scripts/generate_test_health.py"
echo ""
exit 0
