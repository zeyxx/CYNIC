[Unit]
Description=CYNIC Hermes Feedback Loop ‚Äî ingests verdicts and updates domain wisdom every 1 hour
Documentation=https://github.com/zeyxx/CYNIC/docs/hermes-architecture.md
# After=cynic-kernel.service ‚Äî REMOVED: causes ordering cycle (timers.target‚Üítimer‚Üíkernel‚Üíbasic‚Üítimers.target)
# The SERVICE has After=hermes-x-ingest.service which transitively waits for the kernel.

[Timer]
OnBootSec=5min
OnUnitActiveSec=1h
Persistent=true

[Install]
WantedBy=timers.target
