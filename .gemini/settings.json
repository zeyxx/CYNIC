{
  "mcpServers": {
    "cynic": {
      "command": "/home/user/bin/cynic-kernel-mcp"
    },
    "tailscale": {
      "command": "/home/user/bin/tailscale-mcp"
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|edit_file|replace_in_file|apply_diff|patch",
        "hooks": [
          {
            "type": "command",
            "command": "./.gemini/hooks/coord-claim.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/askesis-session-end.sh"
          }
        ]
      }
    ]
  },
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  }
}
