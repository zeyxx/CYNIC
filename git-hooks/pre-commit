#!/bin/bash
set -e

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
export PYTHONPATH="${REPO_ROOT}:${PYTHONPATH}"

echo "🔍 Running pre-commit gates..."

# Gate 1: Encoding Validation
echo "  [1/5] Validating UTF-8 encoding..."
python scripts/validate_encoding.py || exit 1

# Gate 2: Import Analysis
echo "  [2/5] Checking for circular imports..."
python scripts/analyze_imports.py || exit 1

# Gate 3: Factory Audit
echo "  [3/5] Auditing factory wiring..."
python scripts/audit_factory_wiring.py || exit 1

# Gate 4: Unit Tests + Coverage (ENFORCED - NO SILENT FAILURES)
echo "  [4/7] Running unit tests + coverage (75% minimum)..."
cd "${REPO_ROOT}" && python -m pytest tests/ --cov=cynic --cov-report=term -q \
  || { echo "❌ Tests failed"; exit 1; }

# Gate 5: Code Complexity Analysis (ENFORCED)
echo "  [5/7] Checking cyclomatic complexity (max 10)..."
python scripts/check_complexity.py || exit 1

# Gate 6: Stub Detection (ENFORCED)
echo "  [6/7] Detecting unimplemented stubs..."
python scripts/check_stubs.py || exit 1

# Gate 7: Commit Message Format
echo "  [7/7] Validating commit message format..."
python scripts/validate_commit_message.py || exit 1

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║     ✅ ALL PRE-COMMIT GATES PASSED - SAFE TO COMMIT     ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
exit 0
